#!/usr/bin/bash

default CACHE_DIR       "${WORKSPACE_DIR}/cache/"

# ISO
default OS_VERSION      "12.11.0"
default ISO_FILE        "${CACHE_DIR}debian-${OS_VERSION}.iso"
default ISO_URL         "https://cdimage.debian.org/mirror/cdimage/archive/${OS_VERSION}/amd64/iso-dvd/debian-${OS_VERSION}-amd64-DVD-1.iso"

# VM
default VM_NAME "VM"

default HEADLESS "--type=headless"

default VM_RAM    "4096"
default VM_DISK   "8192"
default VM_NB_CPU "4"
default VM_SSH_PORT 8022
default VBOX_DIR "$HOME/VirtualBox VMs"

# Preseed
default PRESEED_FILE "${CACHE_DIR}${TEMPLATE_NAME}.preseed"

default VM_USER  "Zeus"
default VM_LOGIN "zeus"
default VM_PWD   "1234"
#
default VM_HOSTNAME "$VM_NAME"
default VM_DOMAIN   "$VM_HOSTNAME.localhost"
#
default VM_LOCALE   "fr_FR"
default VM_KEYBOARD "fr"
default VM_TZ       "Europe/Paris"
#
default VM_MIRROR     "mirror.dsi.uca.fr"
default VM_MIRROR_DIR "/debian/debian/"
default VM_PROXY      "$http_proxy"
#
default VM_EXTRA_PACKAGES "openssh-server"

# Install
default POSTINSTALL_FILE  "${WORKSPACE_DIR}/scripts/vm/postinstall.sh"

# Configure
default RECIPES ""